{
  "tui": "fullscreen",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); dir=$(printf '%s' \"$input\" | /usr/bin/python3 -c 'import sys,json;print(json.load(sys.stdin).get(\"workspace\",{}).get(\"project_dir\") or \"\")' 2>/dev/null); s=\"$dir/config/statusline/statusline.sh\"; if [ -n \"$dir\" ] && [ -f \"$s\" ]; then printf '%s' \"$input\" | /bin/bash \"$s\"; fi"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/config/scripts/session-entry-scan.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/config/scripts/pre-tool-use-personal-lock.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/config/scripts/post-tool-use-log.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/config/scripts/session-end-session-dump.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/config/scripts/stop-session-snapshot.sh\""
          }
        ]
      }
    ]
  }
}
